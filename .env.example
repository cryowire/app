# GitHub repository URL for wiring data
# Create from https://github.com/cryowire/template
REPO_URL=https://github.com/<your-user>/<your-repo>.git

# GitHub personal access token (required for push access)
# Generate at: https://github.com/settings/tokens
# Required scope: repo (or Contents read/write for fine-grained tokens)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Host port mappings (change if defaults conflict)
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Cloudflare Tunnel token (required when using tunnel profile)
# Create a tunnel at: https://one.dash.cloudflare.com/ → Networks → Tunnels
TUNNEL_TOKEN=
